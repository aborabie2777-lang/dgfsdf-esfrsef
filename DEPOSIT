export default {
  async fetch(request, env, ctx) {
    return new Response("TON Worker Running ✅");
  },

  async scheduled(event, env, ctx) {
    console.log("Starting TON deposit check...");

    const wallet = env.WALLET_ADDRESS;

    // 🔹 جلب آخر المعاملات من TON API
    const response = await fetch(
      `https://toncenter.com/api/v2/getTransactions?address=${wallet}&limit=120`,
      {
        headers: {
          "X-API-Key": env.TON_API_KEY
        }
      }
    );

    const data = await response.json();

    if (!data.result) {
      console.log("No transactions found");
      return;
    }

    const transactions = data.result;

    for (const tx of transactions) {

      const txHash = tx.transaction_id.hash;

      if (!tx.in_msg || !tx.in_msg.message) continue;

      let comment = tx.in_msg.message;

      if (!comment) continue;

      comment = comment.trim();

      // 🔹 نتأكد إن الكومنت رقم فقط
      if (!/^\d+$/.test(comment)) continue;

      const userId = comment;

      const amountNano = tx.in_msg.value;
      const amountTon = Number(amountNano) / 1e9;

      if (amountTon <= 0) continue;

      console.log(`Processing deposit for user ${userId}`);

      // 🔹 تحقق هل المعاملة اتعالجت قبل كده
      const checkProcessed = await fetch(
        `${env.FIREBASE_DB_URL}/processed/${txHash}.json`
      );

      const alreadyProcessed = await checkProcessed.json();

      if (alreadyProcessed) {
        console.log("Transaction already processed");
        continue;
      }

      // 🔹 جلب بيانات المستخدم الحالية
      const userRes = await fetch(
        `${env.FIREBASE_DB_URL}/users/${userId}.json`
      );

      const userData = await userRes.json();

      if (!userData) continue;

      // 🔹 حساب البامبو (1 TON = 10,000 Bamboo)
      const bambooEarned = Math.floor(amountTon * 10000);
      const currentBamboo = userData.bamboo || 0;
      const newBambooBalance = currentBamboo + bambooEarned;

      // 🔹 تحديث رصيد البامبو
      await fetch(`${env.FIREBASE_DB_URL}/users/${userId}.json`, {
        method: "PATCH",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          bamboo: newBambooBalance
        })
      });

      // 🔹 تسجيل بيانات الإيداع في deposits
      const txLink = `https://tonscan.org/tx/${encodeURIComponent(txHash)}`;
      const depositTimestamp = Date.now();

      await fetch(`${env.FIREBASE_DB_URL}/users/${userId}/deposits.json`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          amount: amountTon,
          bambooAdded: bambooEarned,
          txHash: txHash,
          txLink: txLink,
          date: new Date(depositTimestamp).toISOString(),
          timestamp: depositTimestamp
        })
      });

      // 🔹 تعليم المعاملة كمُعالجة
      await fetch(`${env.FIREBASE_DB_URL}/processed/${txHash}.json`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(true)
      });

      console.log(`Added ${bambooEarned} Bamboo to user ${userId} (from ${amountTon} TON)`);

      // =========================
      // 🔔 User Message
      // =========================

      const formattedTon = amountTon.toFixed(6);
      const formattedBamboo = bambooEarned.toLocaleString();

      const userMessage = `
🎋 <b>Bamboo Power Activated!</b>

Deposit Received Successfully ✅

━━━━━━━━━━━━━━━━
💰 <b>Amount:</b> ${formattedTon} TON
🎍 <b>Bamboo Added:</b> ${formattedBamboo}
━━━━━━━━━━━━━━━━

Your bamboo factory has received new energy from the forest treasury. The panda warriors are ready to expand production!

The stronger the bamboo empire grows, the greater your rewards will become.

🐼 Welcome back to the forest, warrior.

🔗 <a href="${txLink}">View Transaction</a>
`;

      await fetch(`https://api.telegram.org/bot${env.BOT_TOKEN}/sendMessage`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          chat_id: userId,
          text: userMessage,
          parse_mode: "HTML",
          disable_web_page_preview: false,
          reply_markup: {
            inline_keyboard: [
              [
                {
                  text: "🐼 Open App",
                  url: "https://t.me/PandaBamboBot?startapp="
                }
              ]
            ]
          }
        })
      });

      console.log("Telegram notification sent to user");
    }

    console.log("Deposit check completed.");
  }
};
